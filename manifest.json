{
  "manifest_version": 3,
  "name": "xHunter",
  "version": "1.2.0",
  "description": "Hunt the right job — analyze your CV, tailor it, and write a matching cover letter for any posting with AI.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "xHunter",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": ["https://api.deepseek.com/*"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
